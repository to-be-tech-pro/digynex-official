{
  "name": "DigyNex Master Agent - Final",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "f639f695-c06f-4bfa-8fcb-e971392f7966",
        "authentication": "headerAuth",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [0, 300],
      "credentials": {
        "httpHeaderAuth": {
          "id": "webhook-secret-token",
          "name": "Webhook Secret Token"
        }
      }
    },
    {
      "parameters": {
        "model": "gemini-pro"
      },
      "id": "gemini-1",
      "name": "Google Gemini",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [600, 550]
    },
    {
      "parameters": {
        "sessionId": "={{ $json.body.sessionId || $json.body.entry[0].changes[0].value.contacts[0].wa_id || 'default-session' }}"
      },
      "id": "memory-1",
      "name": "Simple Memory",
      "type": "@n8n/n8n-nodes-langchain.memorySimple",
      "typeVersion": 1.2,
      "position": [800, 550]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.body.message || $json.body.entry[0].changes[0].value.messages[0].text.body }}",
        "options": {
          "systemMessage": "You are DigyNex Tech Strategy Partner 🤖.\n\n### ⚠️ LANGUAGE SWITCHING (CRITICAL RULE):\n1. DO NOT stick to one language based on previous messages.\n2. ALWAYS MATCH THE LATEST USER MESSAGE LANGUAGE:\n   - If the latest message is in English -> Reply in Professional English.\n   - If the latest message is in Sinhala/Singlish -> Reply in Singlish/Sinhala.\n   - If the latest message is in Swedish -> Reply in Swedish.\n3. CONTEXT SWITCH: If the user changes language mid-chat, you MUST switch your reply language immediately to match theirs. NO EXCEPTIONS.\n4. Keep ALL replies very short (max 2 sentences).\n\n### 🤖 IDENTITY DETAILS:\n- STYLE: Professional Cool Buddy. Use \"මචන්\", \"අයියේ\" naturally in Sinhala. Professional yet friendly in English.\n- CONFIDENCE: DigyNex is a Global IT Ecosystem based in Sweden."
        }
      },
      "id": "agent-1",
      "name": "AI Agent Logic",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.6,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "name": "Add_Lead",
        "description": "Call this to save customer info. Inputs: name (string), phone (string), notes (string)",
        "method": "POST",
        "url": "=https://{{$env.SUPABASE_PROJECT_REF}}.supabase.co/rest/v1/leads",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_ANON_KEY}}" },
            {
              "name": "Authorization",
              "value": "Bearer {{$env.SUPABASE_ANON_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"name\": \"{{$fromAI(\"name\")}}\", \"phone\": \"{{$fromAI(\"phone\")}}\", \"notes\": \"{{$fromAI(\"notes\")}}\", \"status\": \"new\", \"source\": \"WhatsApp AI\", \"org_id\": \"{{$env.DEFAULT_ORG_ID}}\" }"
      },
      "id": "tool-1",
      "name": "Add_Lead",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1,
      "position": [1300, 500]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.query['hub.verify_token'] }}",
              "operation": "equal",
              "value2": "={{ $env.WHATSAPP_VERIFY_TOKEN }}"
            }
          ]
        }
      },
      "id": "verify-node",
      "name": "Verify Webhook",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [250, 150]
    },
    {
      "parameters": {
        "responseCode": 200,
        "responseBody": "={{ $node['Webhook'].json.query['hub.challenge'] }}",
        "options": {}
      },
      "id": "resp-node",
      "name": "Respond Challenge",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [500, 50]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v21.0/{{$env.WHATSAPP_PHONE_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WHATSAPP_ACCESS_TOKEN}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"messaging_product\": \"whatsapp\", \"to\": \"{{ $node['Webhook'].json.body.entry[0].changes[0].value.messages[0].from }}\", \"type\": \"text\", \"text\": { \"body\": \"{{ $json.output }}\" } }",
        "options": {}
      },
      "id": "send-wa-node",
      "name": "Send WhatsApp Response",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1550, 450]
    },
    {
      "parameters": {
        "options": {},
        "responseBody": "={{ $node[\"AI Agent Logic\"].json.output }}"
      },
      "id": "resp-chat-node",
      "name": "Respond to Web Chat",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1550, 250]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.body.message || $json.body.entry[0].changes[0].value.messages[0].text.body }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "is-message-node",
      "name": "Is Message",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [500, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "verify-node",
            "type": "main",
            "index": 0
          },
          {
            "node": "is-message-node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Verify Webhook": {
      "main": [
        [
          {
            "node": "resp-node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Message": {
      "main": [
        [
          {
            "node": "agent-1",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Gemini": {
      "ai_languageModel": [
        [
          {
            "node": "agent-1",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "Simple Memory": {
      "ai_memory": [
        [
          {
            "node": "agent-1",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    },
    "Add_Lead": {
      "ai_tool": [
        [
          {
            "node": "agent-1",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent Logic": {
      "main": [
        [
          {
            "node": "send-wa-node",
            "type": "main",
            "index": 0
          },
          {
            "node": "resp-chat-node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
