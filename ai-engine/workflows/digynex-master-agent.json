            "index": 0
          }
        ]
      ]
    },
    "Add_Lead": {
      "ai_tool": [
        [
          {
            "node": "agent-1",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    },
    "AI Agent Logic": {
      "main": [
        [
          {
            "node": "send-wa-node",
            "type": "main",
            "index": 0
          },
          {
            "node": "resp-chat-node",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
